# ── NVIDIA (embeddings + vision) ─────────────────────────────────────────────
NVIDIA_EMBED_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Cerebras (diagnosis / CRAG / explainability LLM) ─────────────────────────
CEREBRAS_API_KEY=csapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── PostgreSQL + pgvector (Supabase) ─────────────────────────────────────────
# Format: postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
PGVECTOR_DATABASE_URL=postgresql://postgres:yourpassword@db.youref.supabase.co:5432/postgres

# ── Supabase Storage (med-docs bucket) ───────────────────────────────────────
# Project URL from Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
# service_role key (backend only — never expose to frontend)
SUPABASE_SERVICE_KEY=
# anon/public key (safe for frontend use)
SUPABASE_ANON_KEY=

# ── Optional overrides ────────────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO
# Your Vercel frontend URL – added to CORS allow_origins on the backend
ALLOWED_ORIGIN=https://your-app.vercel.app
